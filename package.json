{
  "name": "gheart",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tinder for pull request reviews — swipe right to approve, left to request changes.",
  "scripts": {
    "dev": "concurrently -k -n server,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "seed:brain": "tsx scripts/seed-brain.ts",
    "precompute": "tsx scripts/precompute.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
